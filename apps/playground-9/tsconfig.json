{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "strict": true,
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,
    "lib": ["ESNext", "DOM"],
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vite/client", "node"],
    "paths": {
      "@feugene/granularity": [
        "../../packages/granularity/src/index.ts"
      ],
      "@feugene/granularity/components/*": [
        "../../packages/granularity/src/components/*/index.ts"
      ],
      "@feugene/granularity/uno-node": [
        "../../packages/granularity/src/unocss/preset.node.ts"
      ]
    }
  },
  "vueCompilerOptions": {
    "target": 3.3
  },
  "include": [
    "vite.config.ts",
    "vite-env.d.ts",
    "components.d.ts",
    "uno.config.ts",
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.vue"
  ],
  "exclude": ["node_modules", "dist"]
}
