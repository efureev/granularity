{
  "name": "@feugene/granularity-showcase",
  "private": true,
  "version": "0.4.0",
  "type": "module",
  "dependencies": {
    "@feugene/fint-i18n": "^0.3.0",
    "@feugene/granularity": "^0.12.0",
    "@feugene/granularity-datepicker": "^0.1.1",
    "@feugene/unocss-mini-extra-rules": "^0.3.0",
    "@feugene/unocss-preset-granular": "^0.4.0",
    "vue": "^3.5.40",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@feugene/unplugin-granularity": "^0.4.0",
    "@playwright/test": "^1.61.1",
    "@unocss/reset": "^66.7.5",
    "@vitejs/plugin-vue": "^6.0.8",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^6.0.2",
    "unocss": "^66.7.5",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "vue-component-meta": "^3.3.7"
  },
  "scripts": {
    "build": "yarn generate:api && yarn generate:search && vite build",
    "build:analyze": "yarn generate:api && yarn generate:search && vite build --mode analyze",
    "dev": "yarn prepare:granularity && yarn generate:api && yarn generate:search && vite",
    "generate:api": "node ./scripts/generate-component-api.mjs",
    "generate:search": "node ./scripts/generate-showcase-search-index.mjs",
    "generate:search:local": "yarn prepare:granularity && node ./scripts/generate-showcase-search-index.mjs",
    "prepare:granularity": "yarn workspace @feugene/granularity build",
    "test": "yarn generate:api && yarn generate:search && vitest --config vitest.config.ts",
    "test:run": "yarn generate:api && yarn generate:search && vitest run --config vitest.config.ts",
    "test:e2e": "yarn build && playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:a11y": "yarn build && playwright test e2e/a11y.spec.ts",
    "test:visual": "yarn build && playwright test e2e/visual.spec.ts",
    "test:visual:update": "yarn build && playwright test e2e/visual.spec.ts --update-snapshots"
  }
}
