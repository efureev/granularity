{
  "name": "@feugene/granularity",
  "description": "Granularity design system package with Vue 3 components, consumed via the `@feugene/unocss-preset-granular` preset.",
  "version": "0.2.0",
  "license": "SEE LICENSE IN LICENSE",
  "author": {
    "name": "Evgeniy Fureev",
    "url": "https://github.com/efureev"
  },
  "homepage": "https://efureev.github.io/granularity",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/efureev/granularity.git",
    "directory": "packages/granularity"
  },
  "bugs": {
    "url": "https://github.com/efureev/granularity/issues"
  },
  "keywords": [
    "vue",
    "vue3",
    "design-system",
    "components",
    "ui",
    "ui-kit",
    "granular",
    "unocss-preset-granular",
    "tree-shakeable",
    "typescript"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "types": "./dist/types/src/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./components/DsAlert": {
      "types": "./dist/types/src/components/DsAlert/index.d.ts",
      "import": "./dist/components/DsAlert/index.js"
    },
    "./components/DsButton": {
      "types": "./dist/types/src/components/DsButton/index.d.ts",
      "import": "./dist/components/DsButton/index.js"
    },
    "./components/DsCard": {
      "types": "./dist/types/src/components/DsCard/index.d.ts",
      "import": "./dist/components/DsCard/index.js"
    },
    "./components/DsFormField": {
      "types": "./dist/types/src/components/DsFormField/index.d.ts",
      "import": "./dist/components/DsFormField/index.js"
    },
    "./components/DsInput": {
      "types": "./dist/types/src/components/DsInput/index.d.ts",
      "import": "./dist/components/DsInput/index.js"
    },
    "./components/DsRadio": {
      "types": "./dist/types/src/components/DsRadio/index.d.ts",
      "import": "./dist/components/DsRadio/index.js"
    },
    "./granular-provider": {
      "types": "./dist/types/src/granular-provider/index.d.ts",
      "import": "./dist/granular-provider.js",
      "default": "./dist/granular-provider.js"
    },
    "./granular-provider/node": {
      "types": "./dist/types/src/granular-provider/node.d.ts",
      "import": "./dist/granular-provider-node.js",
      "default": "./dist/granular-provider-node.js"
    }
  },
  "peerDependencies": {
    "@feugene/unocss-preset-granular": "^0.2.0",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@feugene/unocss-preset-granular": "^0.2.0",
    "@iconify-json/lucide": "^1.2.101",
    "@types/node": "^25.5.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.3",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.2",
    "unplugin-icons": "^23.0.1",
    "vite": "^8.0.7",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "vitest": "^4.1.3",
    "vue": "^3.5.32",
    "vue-tsc": "^3.2.6"
  },
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json",
    "dev": "vite build --watch",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "test": "vitest --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.23"
  }
}
